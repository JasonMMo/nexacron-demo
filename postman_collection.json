{
  "info": {
    "name": "Nexacro Demo API",
    "description": "Apple Reminders Clone API Documentation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9090",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
          },
          "response": []
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/categories"
          },
          "response": []
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/categories/1"
          },
          "response": []
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Work\",\n  \"description\": \"Work related tasks\"\n}"
            },
            "url": "{{baseUrl}}/api/categories"
          },
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Work\",\n  \"description\": \"Updated work description\"\n}"
            },
            "url": "{{baseUrl}}/api/categories/1"
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/categories/1"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reminders",
      "item": [
        {
          "name": "Get All Reminders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders"
          },
          "response": []
        },
        {
          "name": "Get Reminder by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/1"
          },
          "response": []
        },
        {
          "name": "Create Reminder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Team Meeting\",\n  \"description\": \"Weekly team sync meeting\",\n  \"priority\": \"HIGH\",\n  \"categoryId\": 1\n}"
            },
            "url": "{{baseUrl}}/api/reminders"
          },
          "response": []
        },
        {
          "name": "Update Reminder",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Team Meeting\",\n  \"description\": \"Updated meeting description\",\n  \"priority\": \"MEDIUM\",\n  \"categoryId\": 1\n}"
            },
            "url": "{{baseUrl}}/api/reminders/1"
          },
          "response": []
        },
        {
          "name": "Delete Reminder",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/1"
          },
          "response": []
        },
        {
          "name": "Toggle Reminder Completion",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/1/complete"
          },
          "response": []
        },
        {
          "name": "Get Reminders by Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/category/1"
          },
          "response": []
        },
        {
          "name": "Get Overdue Reminders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/overdue"
          },
          "response": []
        },
        {
          "name": "Get Reminders by Priority",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/priority/HIGH"
          },
          "response": []
        },
        {
          "name": "Search Reminders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "1"
              }
            ],
            "url": "{{baseUrl}}/api/reminders/search?keyword=meeting"
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          "// Set default user ID for testing",
          "if (!pm.variables.get('userId')) {",
          "  pm.variables.set('userId', '1');",
          "}"
        ]
      }
    }
  ]
}